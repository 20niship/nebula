#version 450
#extension GL_EXT_nonuniform_qualifier : enable
#include "common.glsl"

// λ バッファをゼロクリア (サブステップ毎に実行)
// vkCmdFillBuffer の代替: blit エンコーダー遷移を排除して MoltenVK 高速化

layout(local_size_x = 256) in;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.edgeCount) return;
    writeFloat(pc.lambdasIdx, i, 0.0);
}
